  "validate_rules": [
    {
      "_comment": "数值校验规则"
    },
    {
      "attr": "r1",
      "cond": "not_zero",
      "msg": "曲率半径 R1 和 R2 不能为零。"
    },
    {
      "attr": "r2",
      "cond": "not_zero",
      "msg": "曲率半径 R1 和 R2 不能为零。"
    },
    {
      "attr": "n",
      "cond": "ge_1",
      "msg": "折射率 n 必须大于等于 1.0。"
    },
    {
      "attr": "tc",
      "cond": "gt_0",
      "msg": "中心厚度 Tc 必须大于 0。"
    },
    {
      "attr": "s1_ca",
      "cond": "le_diameter",
      "msg": "S1 CA 不能大于外径。"
    },
    {
      "attr": "s2_ca",
      "cond": "le_diameter",
      "msg": "S2 CA 不能大于外径。"
    }
  ]
}