{
  "_comment": "field_schema.json — 单一真相源。新增字段只需修改此文件。default 值决定 GUI 默认输入和 LensParams 默认值。",
  "gui_sections": [
    {
      "title": "透镜基本参数",
      "_comment": "曲率半径R1/R2、直径D、中心厚Tc、折射率n为基础光学输入",
      "fields": [
        {
          "attr": "material",
          "label": "透镜材料",
          "type": "str",
          "default": "Corning 7980 ArF 0C",
          "_comment": "材料牌号"
        },
        {
          "attr": "r1",
          "label": "R1 (曲率半径)",
          "unit": "mm",
          "type": "float",
          "default": 21.775,
          "_comment": "第1面曲率半径"
        },
        {
          "attr": "r2",
          "label": "R2 (曲率半径)",
          "unit": "mm",
          "type": "float",
          "default": 36.106,
          "_comment": "第2面曲率半径"
        },
        {
          "attr": "diameter",
          "label": "外径 D",
          "unit": "mm",
          "type": "float",
          "default": 14.0,
          "_comment": "透镜成品外径"
        },
        {
          "attr": "tc",
          "label": "中心厚度 Tc",
          "unit": "mm",
          "type": "float",
          "default": 4.0,
          "_comment": "透镜中心厚度"
        },
        {
          "attr": "n",
          "label": "折射率 n",
          "type": "float",
          "default": 1.458413,
          "_comment": "设计波长下的折射率"
        },
        {
          "attr": "wavelength",
          "label": "参考波长",
          "unit": "nm",
          "type": "float",
          "default": 632.8,
          "_comment": "设计/检测参考波长"
        }
      ]
    },
    {
      "title": "外径与下料公差",
      "_comment": "控制毛坯尺寸和下料余量的公差参数",
      "fields": [
        {
          "attr": "tc_tol",
          "label": "Tc 公差",
          "unit": "mm",
          "type": "float",
          "default": 0.02,
          "_comment": "中心厚度加工公差"
        },
        {
          "attr": "pre_edge",
          "label": "磨边预扩口径增量",
          "unit": "mm",
          "type": "float",
          "default": 1.0,
          "_comment": "磨边前预留口径余量"
        },
        {
          "attr": "blank_d_tol",
          "label": "下料口径公差",
          "unit": "mm",
          "type": "float",
          "default": 0.02,
          "_comment": "毛坯下料外径正公差"
        },
        {
          "attr": "blank_t_tol",
          "label": "下料厚度公差",
          "unit": "mm",
          "type": "float",
          "default": 0.05,
          "_comment": "毛坯下料厚度正公差"
        }
      ]
    },
    {
      "title": "加工量",
      "_comment": "各工序的材料去除量",
      "fields": [
        {
          "attr": "mill_s1",
          "label": "S1面铣磨量",
          "unit": "mm",
          "type": "float",
          "default": 0.2,
          "_comment": "S1面铣磨材料去除量"
        },
        {
          "attr": "mill_s2",
          "label": "S2面铣磨量",
          "unit": "mm",
          "type": "float",
          "default": 0.2,
          "_comment": "S2面铣磨材料去除量"
        },
        {
          "attr": "grinding_polishing_s1",
          "label": "S1精磨抛光量",
          "unit": "mm",
          "type": "float",
          "default": 0.2,
          "_comment": "S1面精磨+抛光总去除量"
        },
        {
          "attr": "grinding_polishing_s2",
          "label": "S2精磨抛光量",
          "unit": "mm",
          "type": "float",
          "default": 0.2,
          "_comment": "S2面精磨+抛光总去除量"
        }
      ]
    },
    {
      "title": "面型指标",
      "_comment": "光学面型质量要求",
      "fields": [
        {
          "attr": "s1_n",
          "label": "S1 光圈数 N",
          "type": "float",
          "default": 2.0,
          "_comment": "S1面牛顿环光圈数"
        },
        {
          "attr": "s1_irr",
          "label": "S1 IRR",
          "unit": "λ",
          "type": "float",
          "default": 0.2,
          "_comment": "S1面局部光圈不规则度"
        },
        {
          "attr": "s2_n",
          "label": "S2 光圈数 N",
          "type": "float",
          "default": 2.0,
          "_comment": "S2面牛顿环光圈数"
        },
        {
          "attr": "s2_irr",
          "label": "S2 IRR",
          "unit": "λ",
          "type": "float",
          "default": 0.2,
          "_comment": "S2面局部光圈不规则度"
        },
        {
          "attr": "s1_rms",
          "label": "S1 RMS",
          "unit": "nm",
          "type": "float",
          "default": 0.0,
          "_comment": "S1面RMS粗糙度"
        },
        {
          "attr": "s2_rms",
          "label": "S2 RMS",
          "unit": "nm",
          "type": "float",
          "default": 0.0,
          "_comment": "S2面RMS粗糙度"
        },
        {
          "attr": "roughness_s1",
          "label": "粗糙度 S1",
          "unit": "nm",
          "type": "float",
          "default": 0.8,
          "_comment": "S1面粗糙度要求"
        },
        {
          "attr": "roughness_s2",
          "label": "粗糙度 S2",
          "unit": "nm",
          "type": "float",
          "default": 0.8,
          "_comment": "S2面粗糙度要求"
        }
      ]
    },
    {
      "title": "工艺卡信息",
      "_comment": "工艺卡片元数据，显示在卡片标题和页脚",
      "fields": [
        {
          "attr": "lens_type",
          "label": "产品类型",
          "type": "str",
          "default": "双凸透镜",
          "_comment": "透镜类型，如双凸透镜、平凸透镜等"
        },
        {
          "attr": "drawing_no",
          "label": "图号",
          "type": "str",
          "default": "M0523-G02",
          "_comment": "设计图号"
        },
        {
          "attr": "card_no",
          "label": "工艺卡号",
          "type": "str",
          "default": "NQ0955",
          "_comment": "工艺卡片编号"
        },
        {
          "attr": "author",
          "label": "制定",
          "type": "str",
          "default": "周凡",
          "_comment": "工艺制定人员"
        },
        {
          "attr": "reviewer",
          "label": "审核",
          "type": "str",
          "default": "王千奥",
          "_comment": "工艺审核人员"
        },
        {
          "attr": "approver",
          "label": "批准",
          "type": "str",
          "default": "宋龙",
          "_comment": "工艺批准人员"
        }
      ]
    },
    {
      "title": "检测与加工参数",
      "_comment": "检测区域、边崩、光洁度等",
      "fields": [
        {
          "attr": "s1_sd",
          "label": "S1 S/D",
          "type": "str",
          "default": "20/10",
          "_comment": "S1面光洁度等级"
        },
        {
          "attr": "s2_sd",
          "label": "S2 S/D",
          "type": "str",
          "default": "20/10",
          "_comment": "S2面光洁度等级"
        },
        {
          "attr": "s1_ca",
          "label": "S1 CA (检测口径)",
          "unit": "mm",
          "type": "float",
          "default": 12.0,
          "_comment": "S1面有效检测口径"
        },
        {
          "attr": "s2_ca",
          "label": "S2 CA (检测口径)",
          "unit": "mm",
          "type": "float",
          "default": 12.0,
          "_comment": "S2面有效检测口径"
        },
        {
          "attr": "edge_chip",
          "label": "崩边允许值",
          "unit": "mm",
          "type": "float",
          "default": 0.3,
          "_comment": "崩边最大允许值"
        },
        {
          "attr": "chamfer",
          "label": "倒角",
          "type": "str",
          "default": "(0.2-0.5)x45°",
          "_comment": "倒角规格"
        },
        {
          "attr": "coating_spec",
          "label": "镀膜指标",
          "type": "str",
          "default": "S1、S2：AR-193.368nm，R＜0.5%@193.368nm，AOI=0°±11°",
          "_comment": "镀膜规格要求"
        },
        {
          "attr": "tilt_s1",
          "label": "透射偏心 S1",
          "unit": "′",
          "type": "float",
          "default": 2.0,
          "_comment": "S1面透射偏心允许值（arcmin）"
        },
        {
          "attr": "tilt_s2",
          "label": "透射偏心 S2",
          "unit": "′",
          "type": "float",
          "default": 2.0,
          "_comment": "S2面透射偏心允许值（arcmin）"
        }
      ]
    }
  ],
  "export_ctx": [
    {
      "_comment": "--- LensParams 字段 (source: params) ---"
    },
    {
      "ctx": "${material}",
      "source": "params",
      "attr": "material",
      "fmt": "s"
    },
    {
      "_comment": "透镜基本尺寸"
    },
    {
      "ctx": "${R1}",
      "source": "params",
      "attr": "r1",
      "fmt": ".3f"
    },
    {
      "ctx": "${R2}",
      "source": "params",
      "attr": "r2",
      "fmt": ".3f"
    },
    {
      "ctx": "${Tc}",
      "source": "params",
      "attr": "tc",
      "fmt": ".3f"
    },
    {
      "ctx": "${D}",
      "source": "params",
      "attr": "diameter",
      "fmt": ".1f"
    },
    {
      "_comment": "面型 / 光洁度指标"
    },
    {
      "ctx": "${N_S1}",
      "source": "params",
      "attr": "s1_n",
      "fmt": "s",
      "prefix": "N：≤",
      "hide_zero": true
    },
    {
      "ctx": "${N_S2}",
      "source": "params",
      "attr": "s2_n",
      "fmt": "s",
      "prefix": "N：≤",
      "hide_zero": true
    },
    {
      "ctx": "${IRR_S1}",
      "source": "params",
      "attr": "s1_irr",
      "fmt": "s",
      "prefix": "IRR：≤",
      "suffix": "λ",
      "hide_zero": true
    },
    {
      "ctx": "${IRR_S2}",
      "source": "params",
      "attr": "s2_irr",
      "fmt": "s",
      "prefix": "IRR：≤",
      "suffix": "λ",
      "hide_zero": true
    },
    {
      "ctx": "${RMS_S1}",
      "source": "params",
      "attr": "s1_rms",
      "fmt": ".0f",
      "prefix": "RMS：≤",
      "suffix": "λ",
      "hide_zero": true
    },
    {
      "ctx": "${RMS_S2}",
      "source": "params",
      "attr": "s2_rms",
      "fmt": ".0f",
      "prefix": "RMS：≤",
      "suffix": "λ",
      "hide_zero": true
    },
    {
      "ctx": "${SD_S1}",
      "source": "params",
      "attr": "s1_sd",
      "fmt": "s"
    },
    {
      "ctx": "${SD_S2}",
      "source": "params",
      "attr": "s2_sd",
      "fmt": "s"
    },
    {
      "_comment": "粗糙度"
    },
    {
      "ctx": "${coating_spec}",
      "source": "params",
      "attr": "coating_spec",
      "fmt": "s"
    },
    {
      "ctx": "${roughness_s1}",
      "source": "params",
      "attr": "roughness_s1",
      "fmt": ".1f",
      "suffix": "nm"
    },
    {
      "ctx": "${roughness_s2}",
      "source": "params",
      "attr": "roughness_s2",
      "fmt": ".1f",
      "suffix": "nm"
    },
    {
      "_comment": "CA 检测口径"
    },
    {
      "ctx": "${CA_S1}",
      "source": "params",
      "attr": "s1_ca",
      "fmt": ".0f"
    },
    {
      "ctx": "${CA_S2}",
      "source": "params",
      "attr": "s2_ca",
      "fmt": ".0f"
    },
    {
      "_comment": "加严 CA（按毛坯比例放大）"
    },
    {
      "ctx": "${CA_S1_strict}",
      "source": "result",
      "attr": "s1_ca_strict",
      "fmt": ".1f",
      "label": "S1 加严 CA"
    },
    {
      "ctx": "${CA_S2_strict}",
      "source": "result",
      "attr": "s2_ca_strict",
      "fmt": ".1f",
      "label": "S2 加严 CA"
    },
    {
      "_comment": "加工去除量"
    },
    {
      "ctx": "${mill_s1}",
      "source": "params",
      "attr": "mill_s1",
      "fmt": ".2f"
    },
    {
      "ctx": "${mill_s2}",
      "source": "params",
      "attr": "mill_s2",
      "fmt": ".2f"
    },
    {
      "ctx": "${grinding_polishing_s1}",
      "source": "params",
      "attr": "grinding_polishing_s1",
      "fmt": ".2f"
    },
    {
      "ctx": "${grinding_polishing_s2}",
      "source": "params",
      "attr": "grinding_polishing_s2",
      "fmt": ".2f"
    },
    {
      "_comment": "--- CalcResult 字段 (source: result) ---"
    },
    {
      "_comment": "焦距 / 后焦距"
    },
    {
      "ctx": "${focal}",
      "source": "result",
      "attr": "focal_length",
      "fmt": ".0f",
      "label": "焦距 f"
    },
    {
      "_comment": "下料 / 毛坯尺寸"
    },
    {
      "ctx": "${blank_d}",
      "source": "result",
      "attr": "blank_diameter",
      "fmt": ".1f",
      "label": "毛坯外径"
    },
    {
      "ctx": "${blank_t}",
      "source": "result",
      "attr": "blank_thickness",
      "fmt": ".3f",
      "label": "毛坯厚度"
    },
    {
      "_comment": "各工序后的中心厚度"
    },
    {
      "ctx": "${tc_mill1}",
      "source": "result",
      "attr": "tc_after_mill_s1",
      "fmt": ".3f",
      "label": "铣磨S1后中厚"
    },
    {
      "ctx": "${tc_mill2}",
      "source": "result",
      "attr": "tc_after_mill_s2",
      "fmt": ".3f",
      "label": "铣磨S2后中厚"
    },
    {
      "ctx": "${tc_polish1}",
      "source": "result",
      "attr": "tc_after_grinding_s1",
      "fmt": ".3f",
      "label": "抛光S1后中厚"
    },
    {
      "ctx": "${tc_polish2}",
      "source": "result",
      "attr": "tc_after_grinding_s2",
      "fmt": ".3f",
      "label": "抛光S2后中厚"
    },
    {
      "_comment": "精磨量 / 抛光量（由精磨抛光总量拆分）"
    },
    {
      "ctx": "${grinding_s1}",
      "source": "result",
      "attr": "grinding_s1",
      "fmt": ".2f",
      "label": "S1 精磨量"
    },
    {
      "ctx": "${grinding_s2}",
      "source": "result",
      "attr": "grinding_s2",
      "fmt": ".2f",
      "label": "S2 精磨量"
    },
    {
      "ctx": "${polishing_s1}",
      "source": "result",
      "attr": "polishing_s1",
      "fmt": ".2f",
      "label": "S1 抛光量"
    },
    {
      "ctx": "${polishing_s2}",
      "source": "result",
      "attr": "polishing_s2",
      "fmt": ".2f",
      "label": "S2 抛光量"
    },
    {
      "_comment": "曲率半径公差范围"
    },
    {
      "ctx": "${r1_upper}",
      "source": "result",
      "attr": "r1_upper",
      "fmt": ".4f",
      "label": "R1 上限"
    },
    {
      "ctx": "${r1_lower}",
      "source": "result",
      "attr": "r1_lower",
      "fmt": ".4f",
      "label": "R1 下限"
    },
    {
      "ctx": "${r2_upper}",
      "source": "result",
      "attr": "r2_upper",
      "fmt": ".4f",
      "label": "R2 上限"
    },
    {
      "ctx": "${r2_lower}",
      "source": "result",
      "attr": "r2_lower",
      "fmt": ".4f",
      "label": "R2 下限"
    },
    {
      "_comment": "偏心 / 面倾斜"
    },
    {
      "ctx": "${tilt_s1}",
      "source": "params",
      "attr": "tilt_s1",
      "fmt": ".1f"
    },
    {
      "ctx": "${tilt_s2}",
      "source": "params",
      "attr": "tilt_s2",
      "fmt": ".1f"
    },
    {
      "_comment": "边厚差 / 矢高"
    },
    {
      "ctx": "${edge_thick}",
      "source": "result",
      "attr": "edge_thick_diff_s1",
      "fmt": ".3f",
      "label": "边厚差"
    },
    {
      "ctx": "${sag_s1}",
      "source": "result",
      "attr": "sag_s1",
      "fmt": ".4f",
      "label": "S1 矢高"
    },
    {
      "ctx": "${sag_s2}",
      "source": "result",
      "attr": "sag_s2",
      "fmt": ".4f",
      "label": "S2 矢高"
    },
    {
      "_comment": "后焦距"
    },
    {
      "ctx": "${bfl_s1}",
      "source": "result",
      "attr": "back_focal_s1",
      "fmt": ".2f",
      "label": "后焦距 BFL_S1"
    },
    {
      "ctx": "${bfl_s2}",
      "source": "result",
      "attr": "back_focal_s2",
      "fmt": ".2f",
      "label": "后焦距 BFL_S2"
    },
    {
      "_comment": "矢高差/最大矢高/R最大值"
    },
    {
      "ctx": "${sag_diff_s1}",
      "source": "result",
      "attr": "sag_diff_s1",
      "fmt": ".6f",
      "label": "S1 矢高差"
    },
    {
      "ctx": "${sag_diff_s2}",
      "source": "result",
      "attr": "sag_diff_s2",
      "fmt": ".6f",
      "label": "S2 矢高差"
    },
    {
      "ctx": "${sag_max_s1}",
      "source": "result",
      "attr": "sag_max_s1",
      "fmt": ".6f",
      "label": "S1 最大矢高"
    },
    {
      "ctx": "${sag_max_s2}",
      "source": "result",
      "attr": "sag_max_s2",
      "fmt": ".6f",
      "label": "S2 最大矢高"
    },
    {
      "ctx": "${r_max_s1}",
      "source": "result",
      "attr": "r_max_s1",
      "fmt": ".4f",
      "label": "R1 最大值(矢高反推)"
    },
    {
      "ctx": "${r_max_s2}",
      "source": "result",
      "attr": "r_max_s2",
      "fmt": ".4f",
      "label": "R2 最大值(矢高反推)"
    },
    {
      "_comment": "样板精度 / ΔR"
    },
    {
      "ctx": "${sample_precision_r1}",
      "source": "result",
      "attr": "r1_sample_precision",
      "fmt": ".1f",
      "suffix": "µm",
      "label": "R1 A级样板精度"
    },
    {
      "ctx": "${sample_precision_r2}",
      "source": "result",
      "attr": "r2_sample_precision",
      "fmt": ".1f",
      "suffix": "µm",
      "label": "R2 A级样板精度"
    },
    {
      "ctx": "${dr_with_sample_r1}",
      "source": "result",
      "attr": "r1_dr_with_sample",
      "fmt": ".4f",
      "label": "R1 ΔR(含样板)"
    },
    {
      "ctx": "${dr_with_sample_r2}",
      "source": "result",
      "attr": "r2_dr_with_sample",
      "fmt": ".4f",
      "label": "R2 ΔR(含样板)"
    },
    {
      "ctx": "${dr_no_sample_r1}",
      "source": "result",
      "attr": "r1_dr_no_sample",
      "fmt": ".4f",
      "label": "R1 ΔR(不含样板)"
    },
    {
      "ctx": "${dr_no_sample_r2}",
      "source": "result",
      "attr": "r2_dr_no_sample",
      "fmt": ".4f",
      "label": "R2 ΔR(不含样板)"
    },
    {
      "_comment": "实际上下限文字（小R值用µm，大R值用mm）"
    },
    {
      "ctx": "${r1_actual_upper}",
      "source": "result",
      "attr": "r1_actual_upper",
      "fmt": "s",
      "label": "R1 实际显示上限"
    },
    {
      "ctx": "${r1_actual_lower}",
      "source": "result",
      "attr": "r1_actual_lower",
      "fmt": "s",
      "label": "R1 实际显示下限"
    },
    {
      "ctx": "${r2_actual_upper}",
      "source": "result",
      "attr": "r2_actual_upper",
      "fmt": "s",
