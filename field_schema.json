{
  "_comment": "field_schema.json — 单一真相源。新增字段只需修改此文件。default 值决定 GUI 默认输入和 LensParams 默认值。",
  "gui_sections": [
    {
      "title": "透镜基本参数",
      "_comment": "曲率半径R1/R2、直径D、中心厚Tc、折射率n为基础光学输入",
      "fields": [
        {
          "attr": "material",
          "label": "透镜材料",
          "type": "str",
          "default": "Corning 7980 KrF",
          "_comment": "材料牌号"
        },
        {
          "attr": "r1",
          "label": "R1 (曲率半径)",
          "unit": "mm",
          "type": "float",
          "default": 284.241,
          "_comment": "第1面曲率半径"
        },
        {
          "attr": "r2",
          "label": "R2 (曲率半径)",
          "unit": "mm",
          "type": "float",
          "default": 24.944,
          "_comment": "第2面曲率半径"
        },
        {
          "attr": "diameter",
          "label": "外径 D",
          "unit": "mm",
          "type": "float",
          "default": 15.0,
          "_comment": "透镜成品外径"
        },
        {
          "attr": "tc",
          "label": "中心厚度 Tc",
          "unit": "mm",
          "type": "float",
          "default": 2.42,
          "_comment": "透镜中心厚度"
        },
        {
          "attr": "n",
          "label": "折射率 n",
          "type": "float",
          "default": 1.458406,
          "_comment": "设计波长下的折射率"
        },
        {
          "attr": "wavelength",
          "label": "参考波长",
          "unit": "nm",
          "type": "float",
          "default": 632.8,
          "_comment": "设计/检测参考波长"
        }
      ]
    },
    {
      "title": "外径与下料公差",
      "_comment": "控制毛坯尺寸和下料余量的公差参数",
      "fields": [
        {
          "attr": "tc_tol",
          "label": "Tc 公差",
          "unit": "mm",
          "type": "float",
          "default": 0.02,
          "_comment": "中心厚度加工公差"
        },
        {
          "attr": "pre_edge",
          "label": "磨边预扩口径增量",
          "unit": "mm",
          "type": "float",
          "default": 2.0,
          "_comment": "磨边前预留口径余量"
        },
        {
          "attr": "blank_t_tol",
          "label": "下料厚度公差",
          "unit": "mm",
          "type": "float",
          "default": 0.05,
          "_comment": "毛坯下料厚度正公差"
        }
      ]
    },
    {
      "title": "加工量",
      "_comment": "各工序的材料去除量",
      "fields": [
        {
          "attr": "grind_s1",
          "label": "S1面铣磨量",
          "unit": "mm",
          "type": "float",
          "default": 0.15,
          "_comment": "S1面铣磨材料去除量"
        },
        {
          "attr": "grind_s2",
          "label": "S2面铣磨量",
          "unit": "mm",
          "type": "float",
          "default": 1.8,
          "_comment": "S2面铣磨材料去除量"
        },
        {
          "attr": "polish_s1",
          "label": "S1细磨抛光量",
          "unit": "mm",
          "type": "float",
          "default": 0.16,
          "_comment": "S1面细磨+抛光去除量"
        },
        {
          "attr": "polish_s2",
          "label": "S2细磨抛光量",
          "unit": "mm",
          "type": "float",
          "default": 0.16,
          "_comment": "S2面细磨+抛光去除量"
        }
      ]
    },
    {
      "title": "面型指标",
      "_comment": "光学面型质量要求",
      "fields": [
        {
          "attr": "s1_n",
          "label": "S1 光圈数 N",
          "type": "float",
          "default": 1.0,
          "_comment": "S1面牛顿环光圈数"
        },
        {
          "attr": "s1_irr",
          "label": "S1 IRR",
          "unit": "λ",
          "type": "float",
          "default": 0.1,
          "_comment": "S1面局部光圈不规则度"
        },
        {
          "attr": "s2_n",
          "label": "S2 光圈数 N",
          "type": "float",
          "default": 1.0,
          "_comment": "S2面牛顿环光圈数"
        },
        {
          "attr": "s2_irr",
          "label": "S2 IRR",
          "unit": "λ",
          "type": "float",
          "default": 0.1,
          "_comment": "S2面局部光圈不规则度"
        },
        {
          "attr": "s1_rms",
          "label": "S1 RMS",
          "unit": "nm",
          "type": "float",
          "default": 4.0,
          "_comment": "S1面RMS粗糙度"
        },
        {
          "attr": "s2_rms",
          "label": "S2 RMS",
          "unit": "nm",
          "type": "float",
          "default": 4.0,
          "_comment": "S2面RMS粗糙度"
        },
        {
          "attr": "roughness_s1",
          "label": "粗糙度 S1",
          "unit": "nm",
          "type": "float",
          "default": 1.0,
          "_comment": "S1面粗糙度要求"
        },
        {
          "attr": "roughness_s2",
          "label": "粗糙度 S2",
          "unit": "nm",
          "type": "float",
          "default": 1.0,
          "_comment": "S2面粗糙度要求"
        }
      ]
    },
    {
      "title": "工艺卡信息",
      "_comment": "工艺卡片元数据，显示在卡片标题和页脚",
      "fields": [
        {
          "attr": "lens_type",
          "label": "产品类型",
          "type": "str",
          "default": "双凸透镜",
          "_comment": "透镜类型，如双凸透镜、平凸透镜等"
        },
        {
          "attr": "drawing_no",
          "label": "图号",
          "type": "str",
          "default": "M0454-G10",
          "_comment": "设计图号"
        },
        {
          "attr": "card_no",
          "label": "工艺卡号",
          "type": "str",
          "default": "NQ0871",
          "_comment": "工艺卡片编号"
        },
        {
          "attr": "author",
          "label": "制定",
          "type": "str",
          "default": "周凡",
          "_comment": "工艺制定人员"
        },
        {
          "attr": "reviewer",
          "label": "审核",
          "type": "str",
          "default": "王千奥",
          "_comment": "工艺审核人员"
        },
        {
          "attr": "approver",
          "label": "批准",
          "type": "str",
          "default": "宋龙",
          "_comment": "工艺批准人员"
        }
      ]
    },
    {
      "title": "检测与加工参数",
      "_comment": "检测区域、边崩、光洁度等",
      "fields": [
        {
          "attr": "s1_sd",
          "label": "S1 S/D",
          "type": "str",
          "default": "10/5",
          "_comment": "S1面光洁度等级"
        },
        {
          "attr": "s2_sd",
          "label": "S2 S/D",
          "type": "str",
          "default": "10/5",
          "_comment": "S2面光洁度等级"
        },
        {
          "attr": "s1_ca",
          "label": "S1 CA (检测口径)",
          "unit": "mm",
          "type": "float",
          "default": 15.0,
          "_comment": "S1面有效检测口径"
        },
        {
          "attr": "s2_ca",
          "label": "S2 CA (检测口径)",
          "unit": "mm",
          "type": "float",
          "default": 14.0,
          "_comment": "S2面有效检测口径"
        },
        {
          "attr": "edge_chip",
          "label": "崩边允许值",
          "unit": "mm",
          "type": "float",
          "default": 0.3,
          "_comment": "崩边最大允许值"
        },
        {
          "attr": "chamfer",
          "label": "倒角",
          "type": "str",
          "default": "(0.2-0.5)x45°",
          "_comment": "倒角规格"
        },
        {
          "attr": "coating_spec",
          "label": "镀膜指标",
          "type": "str",
          "default": "S1、S2：AR-193.368nm，R＜0.5%@193.368nm，AOI=0°±35°",
          "_comment": "镀膜规格要求"
        },
        {
          "attr": "trays_s1",
          "label": "S1 每盘数量",
          "type": "int",
          "default": 1,
          "_comment": "S1面每盘透镜数量"
        },
        {
          "attr": "trays_s2",
          "label": "S2 每盘数量",
          "type": "int",
          "default": 1,
          "_comment": "S2面每盘透镜数量"
        },
        {
          "attr": "tray_diameter",
          "label": "盘径 Dj",
          "unit": "mm",
          "type": "float",
          "default": 67.0,
          "_comment": "加工盘直径"
        }
      ]
    }
  ],
  "export_ctx": [
    {
      "_comment": "--- LensParams 字段 (source: params) ---"
    },
    {
      "ctx": "${material}",
      "source": "params",
      "attr": "material",
      "fmt": "s"
    },
    {
      "_comment": "透镜基本尺寸"
    },
    {
      "ctx": "${R1}",
      "source": "params",
      "attr": "r1",
      "fmt": ".3f"
    },
    {
      "ctx": "${R2}",
      "source": "params",
      "attr": "r2",
      "fmt": ".3f"
    },
    {
      "ctx": "${Tc}",
      "source": "params",
      "attr": "tc",
      "fmt": ".3f"
    },
    {
      "ctx": "${D}",
      "source": "params",
      "attr": "diameter",
      "fmt": ".1f"
    },
    {
      "_comment": "面型 / 光洁度指标"
    },
    {
      "ctx": "${N_S1}",
      "source": "params",
      "attr": "s1_n",
      "fmt": ".0f",
      "hide_zero": true
    },
    {
      "ctx": "${N_S2}",
      "source": "params",
      "attr": "s2_n",
      "fmt": ".0f",
      "hide_zero": true
    },
    {
      "ctx": "${IRR_S1}",
      "source": "params",
      "attr": "s1_irr",
      "fmt": "s",
      "prefix": "IRR：",
      "suffix": "λ",
      "hide_zero": true
    },
    {
      "ctx": "${IRR_S2}",
      "source": "params",
      "attr": "s2_irr",
      "fmt": "s",
      "prefix": "IRR：",
      "suffix": "λ",
      "hide_zero": true
    },
    {
      "ctx": "${RMS_S1}",
      "source": "params",
      "attr": "s1_rms",
      "fmt": ".0f",
      "prefix": "RMS：",
      "suffix": "nm",
      "hide_zero": true
    },
    {
      "ctx": "${RMS_S2}",
      "source": "params",
      "attr": "s2_rms",
      "fmt": ".0f",
      "prefix": "RMS：",
      "suffix": "nm",
      "hide_zero": true
    },
    {
      "ctx": "${SD_S1}",
      "source": "params",
      "attr": "s1_sd",
      "fmt": "s"
    },
    {
      "ctx": "${SD_S2}",
      "source": "params",
      "attr": "s2_sd",
      "fmt": "s"
    },
    {
      "_comment": "粗糙度"
    },
    {
      "ctx": "${coating_spec}",
      "source": "params",
      "attr": "coating_spec",
      "fmt": "s"
    },
    {
      "ctx": "${roughness_s1}",
      "source": "params",
      "attr": "roughness_s1",
      "fmt": ".0f",
      "suffix": "nm"
    },
    {
      "ctx": "${roughness_s2}",
      "source": "params",
      "attr": "roughness_s2",
      "fmt": ".0f",
      "suffix": "nm"
    },
    {
      "_comment": "CA 检测口径"
    },
    {
      "ctx": "${CA_S1}",
      "source": "params",
      "attr": "s1_ca",
      "fmt": ".0f"
    },
    {
      "ctx": "${CA_S2}",
      "source": "params",
      "attr": "s2_ca",
      "fmt": ".0f"
    },
    {
      "_comment": "加工去除量"
    },
    {
      "ctx": "${grind_s1}",
      "source": "params",
      "attr": "grind_s1",
      "fmt": ".2f"
    },
    {
      "ctx": "${grind_s2}",
      "source": "params",
      "attr": "grind_s2",
      "fmt": ".2f"
    },
    {
      "ctx": "${polish_s1}",
      "source": "params",
      "attr": "polish_s1",
      "fmt": ".2f"
    },
    {
      "ctx": "${polish_s2}",
      "source": "params",
      "attr": "polish_s2",
      "fmt": ".2f"
    },
    {
      "_comment": "--- CalcResult 字段 (source: result) ---"
    },
    {
      "_comment": "焦距 / 后焦距"
    },
    {
      "ctx": "${focal}",
      "source": "result",
      "attr": "focal_length",
      "fmt": ".1f"
    },
    {
      "_comment": "下料 / 毛坯尺寸"
    },
    {
      "ctx": "${blank_d}",
      "source": "result",
      "attr": "blank_diameter",
      "fmt": ".1f"
    },
    {
      "ctx": "${blank_t}",
      "source": "result",
      "attr": "blank_thickness",
      "fmt": ".3f"
    },
    {
      "_comment": "各工序后的中心厚度"
    },
    {
      "ctx": "${tc_grind1}",
      "source": "result",
      "attr": "tc_after_grind_s1",
      "fmt": ".3f"
    },
    {
      "ctx": "${tc_grind2}",
      "source": "result",
      "attr": "tc_after_grind_s2",
      "fmt": ".3f"
    },
    {
      "ctx": "${tc_polish1}",
      "source": "result",
      "attr": "tc_after_polish_s1",
      "fmt": ".3f"
    },
    {
      "ctx": "${tc_polish2}",
      "source": "result",
      "attr": "tc_after_polish_s2",
      "fmt": ".3f"
    },
    {
      "_comment": "曲率半径公差范围"
    },
    {
      "ctx": "${r1_upper}",
      "source": "result",
      "attr": "r1_upper",
      "fmt": ".4f"
    },
    {
      "ctx": "${r1_lower}",
      "source": "result",
      "attr": "r1_lower",
      "fmt": ".4f"
    },
    {
      "ctx": "${r2_upper}",
      "source": "result",
      "attr": "r2_upper",
      "fmt": ".4f"
    },
    {
      "ctx": "${r2_lower}",
      "source": "result",
      "attr": "r2_lower",
      "fmt": ".4f"
    },
    {
      "_comment": "偏心 / 面倾斜"
    },
    {
      "ctx": "${tilt_s1}",
      "source": "result",
      "attr": "tilt_s1_per_mm",
      "fmt": ".1f"
    },
    {
      "ctx": "${tilt_s2}",
      "source": "result",
      "attr": "tilt_s2_per_mm",
      "fmt": ".1f"
    },
    {
      "_comment": "边厚差 / 矢高"
    },
    {
      "ctx": "${edge_thick}",
      "source": "result",
      "attr": "edge_thick_diff_s1",
      "fmt": ".3f"
    },
    {
      "ctx": "${sag_s1}",
      "source": "result",
      "attr": "sag_s1",
      "fmt": ".4f"
    },
    {
      "ctx": "${sag_s2}",
      "source": "result",
      "attr": "sag_s2",
      "fmt": ".4f"
    }
  ],
  "validate_rules": [
    {
      "_comment": "数值校验规则"
    },
    {
      "attr": "r1",
      "cond": "not_zero",
      "msg": "曲率半径 R1 和 R2 不能为零。"
    },
    {
      "attr": "r2",
      "cond": "not_zero",
      "msg": "曲率半径 R1 和 R2 不能为零。"
    },
    {
      "attr": "n",
      "cond": "ge_1",
      "msg": "折射率 n 必须大于等于 1.0。"
    },
    {
      "attr": "tc",
      "cond": "gt_0",
      "msg": "中心厚度 Tc 必须大于 0。"
    },
    {
      "attr": "s1_ca",
      "cond": "le_diameter",
      "msg": "S1 CA 不能大于外径。"
    },
    {
      "attr": "s2_ca",
      "cond": "le_diameter",
      "msg": "S2 CA 不能大于外径。"
    }
  ]
}